{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specs.makemind.com/mcp_ui_dsl/1.3/app.schema.json",
  "title": "MCP UI DSL 1.3 — ApplicationDefinition",
  "description": "Top-level application definition per docs/01_Core_Concepts.md §1.2 and bundle metadata per docs/11_Bundle_Metadata.md. Widget and action sub-trees are validated by widgets.schema.json (referenced via #/$defs/Widget and #/$defs/Action — left permissive here so this schema is self-contained).",
  "type": "object",
  "properties": {
    "type":          { "const": "application" },
    "version":       { "$ref": "#/$defs/SemverLike" },
    "id":            { "$ref": "#/$defs/BundleId" },
    "title":         { "type": "string" },
    "description":   { "type": "string" },
    "icon":          { "$ref": "#/$defs/AssetRef" },
    "splash":        { "$ref": "#/$defs/SplashConfig" },
    "category":      { "$ref": "#/$defs/Category" },
    "publisher":     { "$ref": "#/$defs/PublisherInfo" },
    "timestamps":    { "$ref": "#/$defs/TimestampInfo" },
    "screenshots":   { "type": "array", "items": { "$ref": "#/$defs/AssetRef" } },
    "initialRoute":  { "type": "string", "pattern": "^/" },
    "routes":        { "$ref": "#/$defs/Routes" },
    "theme":         { "$ref": "https://specs.makemind.com/mcp_ui_dsl/1.3/theme.schema.json" },
    "navigation":    { "$ref": "#/$defs/NavigationConfig" },
    "state":         { "$ref": "#/$defs/StateBlock" },
    "lifecycle":     { "$ref": "#/$defs/LifecycleHooks" },
    "onInit":        { "$ref": "#/$defs/ActionOrList" },
    "onReady":       { "$ref": "#/$defs/ActionOrList" },
    "onMount":       { "$ref": "#/$defs/ActionOrList" },
    "onPause":       { "$ref": "#/$defs/ActionOrList" },
    "onResume":      { "$ref": "#/$defs/ActionOrList" },
    "onUnmount":     { "$ref": "#/$defs/ActionOrList" },
    "onDestroy":     { "$ref": "#/$defs/ActionOrList" },
    "services":      {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/ServiceDefinition" }
    },
    "templates": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/TemplateDefinition" }
    },
    "templateLibraries": {
      "type": "array",
      "items": { "$ref": "#/$defs/TemplateLibraryRef" }
    },
    "i18n":          { "$ref": "#/$defs/I18nConfig" },
    "permissions":   { "$ref": "#/$defs/PermissionDeclaration" },
    "dashboard":     { "$ref": "#/$defs/DashboardConfig" }
  },
  "required": ["type", "routes"],
  "additionalProperties": false,
  "$defs": {
    "SemverLike": {
      "type": "string",
      "pattern": "^[0-9]+(\\.[0-9]+){0,2}(-[0-9A-Za-z.-]+)?$",
      "description": "Two- or three-part version. `1.3` and `1.3.0` are both accepted; comparison uses major.minor only."
    },
    "BundleId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$",
      "description": "Reverse-DNS bundle identifier (e.g. `com.example.taskflow`)."
    },
    "Category": {
      "type": "string",
      "description": "Free-form. Recommended values: productivity, education, entertainment, social, business, utilities, health, finance, lifestyle, news, travel, food, sports, music, photo, video, communication, developer, reference, other."
    },
    "AssetRef": {
      "type": "string",
      "description": "`bundle://` URI, HTTP(S) URL, or `data:` URI.",
      "pattern": "^(bundle://|https?://|data:)"
    },
    "ColorHex": {
      "type": "string",
      "pattern": "^#([0-9A-Fa-f]{6}|[0-9A-Fa-f]{8})$"
    },
    "Locale": {
      "type": "string",
      "pattern": "^[a-z]{2,3}(-[A-Za-z0-9]{2,8})*$",
      "description": "BCP 47 locale tag (e.g. `en`, `en-US`, `zh-Hant-TW`)."
    },

    "PublisherInfo": {
      "type": "object",
      "properties": {
        "name":    { "type": "string" },
        "logo":    { "$ref": "#/$defs/AssetRef" },
        "website": { "type": "string", "format": "uri" },
        "email":   { "type": "string", "format": "email" }
      },
      "required": ["name"],
      "additionalProperties": false
    },

    "TimestampInfo": {
      "type": "object",
      "properties": {
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },

    "SplashConfig": {
      "type": "object",
      "properties": {
        "image":           { "$ref": "#/$defs/AssetRef" },
        "backgroundColor": { "$ref": "#/$defs/ColorHex" },
        "duration":        { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },

    "RouteValue": {
      "description": "Inline PageDefinition or `ui://` resource URI.",
      "oneOf": [
        { "$ref": "https://specs.makemind.com/mcp_ui_dsl/1.3/page.schema.json" },
        { "type": "string", "pattern": "^ui://" }
      ]
    },
    "Routes": {
      "type": "object",
      "description": "Map of route path (`/path`, `/users/:id`) to inline PageDefinition or `ui://` URI.",
      "propertyNames": { "pattern": "^/" },
      "additionalProperties": { "$ref": "#/$defs/RouteValue" }
    },

    "NavItem": {
      "type": "object",
      "properties": {
        "label":    { "type": "string" },
        "route":    { "type": "string", "pattern": "^/" },
        "icon":     { "type": "string" },
        "badge":    { "type": ["string", "number", "boolean"] },
        "children": { "type": "array", "items": { "$ref": "#/$defs/NavItem" } },
        "onTap":    { "$ref": "#/$defs/Action" }
      },
      "additionalProperties": true
    },
    "NavigationConfig": {
      "type": "object",
      "properties": {
        "type":  { "enum": ["drawer", "bottomBar", "rail", "tabs"] },
        "items": { "type": "array", "items": { "$ref": "#/$defs/NavItem" } },
        "header": { "$ref": "#/$defs/Widget" },
        "footer": { "$ref": "#/$defs/Widget" }
      },
      "required": ["type"],
      "additionalProperties": true
    },

    "StateBlock": {
      "type": "object",
      "properties": {
        "initial": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },

    "LifecycleHooks": {
      "type": "object",
      "properties": {
        "onInit":     { "$ref": "#/$defs/ActionOrList" },
        "onReady":    { "$ref": "#/$defs/ActionOrList" },
        "onMount":    { "$ref": "#/$defs/ActionOrList" },
        "onPause":    { "$ref": "#/$defs/ActionOrList" },
        "onResume":   { "$ref": "#/$defs/ActionOrList" },
        "onUnmount":  { "$ref": "#/$defs/ActionOrList" },
        "onDestroy":  { "$ref": "#/$defs/ActionOrList" }
      },
      "additionalProperties": false
    },

    "ServiceDefinition": {
      "type": "object",
      "description": "Background service launched at app init (polling, subscription, channel). Per docs/06_Runtime_Contract.md and docs/08_Client_Extensions.md.",
      "properties": {
        "kind":        { "enum": ["polling", "subscription", "channel", "websocket", "sse"] },
        "interval":    { "type": "number", "minimum": 0 },
        "url":         { "type": "string" },
        "tool":        { "type": "string" },
        "params":      { "type": "object", "additionalProperties": true },
        "binding":     { "type": "string" },
        "onMessage":   { "$ref": "#/$defs/ActionOrList" },
        "onError":     { "$ref": "#/$defs/ActionOrList" },
        "autoStart":   { "type": "boolean", "default": true }
      },
      "additionalProperties": true
    },

    "TemplateDefinition": {
      "type": "object",
      "description": "Reusable template definition per docs/09_Templates.md.",
      "properties": {
        "params": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "type":     { "type": "string" },
              "required": { "type": "boolean" },
              "default":  {}
            },
            "additionalProperties": true
          }
        },
        "stateDefaults": { "type": "object", "additionalProperties": true },
        "body":          { "$ref": "#/$defs/Widget" },
        "lifecycle":     { "$ref": "#/$defs/LifecycleHooks" }
      },
      "required": ["body"],
      "additionalProperties": true
    },
    "TemplateLibraryRef": {
      "type": "object",
      "properties": {
        "uri":       { "type": "string" },
        "version":   { "$ref": "#/$defs/SemverLike" },
        "namespace": { "type": "string" }
      },
      "required": ["uri"],
      "additionalProperties": true
    },

    "I18nConfig": {
      "type": "object",
      "description": "Locale bundles per docs/12_Internationalization.md §12.1.",
      "properties": {
        "defaultLocale": { "$ref": "#/$defs/Locale" },
        "supportedLocales": {
          "type": "array",
          "items": { "$ref": "#/$defs/Locale" }
        },
        "text": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "plurals": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "numbers": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "dates": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "textDirection": {
          "type": "object",
          "additionalProperties": { "enum": ["ltr", "rtl"] }
        }
      },
      "required": ["defaultLocale"],
      "additionalProperties": true
    },

    "PermissionDeclaration": {
      "description": "Permissions per docs/08_Client_Extensions.md §8.4. Either a flat list of permission names, a profile shorthand, or an object grouping by category.",
      "oneOf": [
        { "type": "array", "items": { "type": "string" } },
        { "enum": ["readonly", "interactive", "full"] },
        {
          "type": "object",
          "additionalProperties": {
            "oneOf": [
              { "type": "array", "items": { "type": "string" } },
              { "type": "object", "additionalProperties": true }
            ]
          }
        }
      ]
    },

    "DashboardConfig": {
      "type": "object",
      "description": "Compact rendering entry point per docs/11_Bundle_Metadata.md §11.9.",
      "properties": {
        "content":         { "$ref": "#/$defs/Widget" },
        "refreshInterval": { "type": "number", "minimum": 0 },
        "onTap":           { "$ref": "#/$defs/Action" }
      },
      "required": ["content"],
      "additionalProperties": false
    },

    "ActionOrList": {
      "oneOf": [
        { "$ref": "#/$defs/Action" },
        { "type": "array", "items": { "$ref": "#/$defs/Action" } }
      ]
    },
    "Action": {
      "type": "object",
      "description": "Action per docs/04_Actions.md. Discriminator `type`; per-type fields are validated by widgets.schema.json's Action def.",
      "properties": {
        "type": { "type": "string" }
      },
      "required": ["type"],
      "additionalProperties": true
    },
    "Widget": {
      "type": "object",
      "description": "Widget per docs/02_Widgets.md. Validated against the union in widgets.schema.json; left permissive here.",
      "properties": {
        "type": { "type": "string" }
      },
      "required": ["type"],
      "additionalProperties": true
    }
  }
}
