{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specs.makemind.com/mcp_ui_dsl/1.3/page.schema.json",
  "title": "MCP UI DSL 1.3 — PageDefinition",
  "description": "Single-screen page definition per docs/01_Core_Concepts.md §1.3. Widget and action sub-trees are validated by widgets.schema.json — left permissive here so this schema is self-contained.",
  "type": "object",
  "properties": {
    "type":          { "enum": ["page", "screen"], "description": "Discriminator. `screen` is a legacy alias accepted for backward compatibility (§17.3.5)." },
    "version":       { "$ref": "#/$defs/SemverLike" },
    "title":         { "type": "string" },
    "content":       { "$ref": "#/$defs/Widget" },
    "themeOverride": { "$ref": "https://specs.makemind.com/mcp_ui_dsl/1.3/theme.schema.json" },
    "state":         { "$ref": "#/$defs/StateBlock" },
    "lifecycle":     { "$ref": "#/$defs/LifecycleHooks" },
    "onInit":        { "$ref": "#/$defs/ActionOrList" },
    "onReady":       { "$ref": "#/$defs/ActionOrList" },
    "onMount":       { "$ref": "#/$defs/ActionOrList" },
    "onPause":       { "$ref": "#/$defs/ActionOrList" },
    "onResume":      { "$ref": "#/$defs/ActionOrList" },
    "onUnmount":     { "$ref": "#/$defs/ActionOrList" },
    "onDestroy":     { "$ref": "#/$defs/ActionOrList" },
    "validation":    { "$ref": "#/$defs/ValidationConfig" },
    "permissions":   { "$ref": "#/$defs/PermissionDeclaration" },
    "channels":      { "$ref": "#/$defs/ChannelMap" }
  },
  "required": ["type", "content"],
  "additionalProperties": false,
  "$defs": {
    "SemverLike": {
      "type": "string",
      "pattern": "^[0-9]+(\\.[0-9]+){0,2}(-[0-9A-Za-z.-]+)?$"
    },

    "StateBlock": {
      "type": "object",
      "properties": {
        "initial": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },

    "LifecycleHooks": {
      "type": "object",
      "properties": {
        "onInit":     { "$ref": "#/$defs/ActionOrList" },
        "onReady":    { "$ref": "#/$defs/ActionOrList" },
        "onMount":    { "$ref": "#/$defs/ActionOrList" },
        "onPause":    { "$ref": "#/$defs/ActionOrList" },
        "onResume":   { "$ref": "#/$defs/ActionOrList" },
        "onUnmount":  { "$ref": "#/$defs/ActionOrList" },
        "onDestroy":  { "$ref": "#/$defs/ActionOrList" }
      },
      "additionalProperties": false
    },

    "ValidationRule": {
      "type": "object",
      "properties": {
        "field":     { "type": "string" },
        "type":      { "type": "string" },
        "value":     {},
        "message":   { "type": "string" },
        "trigger":   { "enum": ["change", "blur", "submit"] }
      },
      "additionalProperties": true
    },
    "ValidationConfig": {
      "description": "Form validation per page. Shape A (object keyed by field) or Shape B (rule list).",
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": {
            "oneOf": [
              { "$ref": "#/$defs/ValidationRule" },
              { "type": "array", "items": { "$ref": "#/$defs/ValidationRule" } }
            ]
          }
        },
        { "type": "array", "items": { "$ref": "#/$defs/ValidationRule" } }
      ]
    },

    "PermissionDeclaration": {
      "description": "Permissions per docs/08_Client_Extensions.md §8.4. Either a list of permission names, a profile shorthand, or an object grouped by category.",
      "oneOf": [
        { "type": "array", "items": { "type": "string" } },
        { "enum": ["readonly", "interactive", "full"] },
        {
          "type": "object",
          "additionalProperties": {
            "oneOf": [
              { "type": "array", "items": { "type": "string" } },
              { "type": "object", "additionalProperties": true }
            ]
          }
        }
      ]
    },

    "ChannelDefinition": {
      "type": "object",
      "description": "Long-lived bidirectional stream per docs/08_Client_Extensions.md §8.6.",
      "properties": {
        "kind":      { "enum": ["websocket", "sse", "channel", "subscription"] },
        "url":       { "type": "string" },
        "tool":      { "type": "string" },
        "params":    { "type": "object", "additionalProperties": true },
        "binding":   { "type": "string" },
        "autoStart": { "type": "boolean", "default": true },
        "onMessage": { "$ref": "#/$defs/ActionOrList" },
        "onOpen":    { "$ref": "#/$defs/ActionOrList" },
        "onClose":   { "$ref": "#/$defs/ActionOrList" },
        "onError":   { "$ref": "#/$defs/ActionOrList" }
      },
      "additionalProperties": true
    },
    "ChannelMap": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/ChannelDefinition" }
    },

    "ActionOrList": {
      "oneOf": [
        { "$ref": "#/$defs/Action" },
        { "type": "array", "items": { "$ref": "#/$defs/Action" } }
      ]
    },
    "Action": {
      "type": "object",
      "description": "Action per docs/04_Actions.md. Discriminator `type`; per-type fields validated by widgets.schema.json's Action def.",
      "properties": {
        "type": { "type": "string" }
      },
      "required": ["type"],
      "additionalProperties": true
    },
    "Widget": {
      "type": "object",
      "description": "Widget per docs/02_Widgets.md. Validated against the union in widgets.schema.json; left permissive here.",
      "properties": {
        "type": { "type": "string" }
      },
      "required": ["type"],
      "additionalProperties": true
    }
  }
}
